{
  "expo": {
    "name": "RealPoint",
    "slug": "realpoint",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "realpoint",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1b6b4a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.realpoint.surat",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload property photos for listings.",
        "NSLocationWhenInUseUsageDescription": "Show your position on the Surat planning map.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1b6b4a"
      },
      "package": "com.realpoint.surat",
      "usesCleartextTraffic": true,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-dev-client",
      "@maplibre/maplibre-react-native",
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1b6b4a"
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RealPoint uses your location to place property listings on the Surat map."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c0753742-550a-425e-af85-d8d60d82f7a3"
      }
    },
    "owner": "veeral1"
  }
}
