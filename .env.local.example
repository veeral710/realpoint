# Generated after `pnpm supabase:start` — copy to .env, apps/web/.env.local, apps/mobile/.env
# Run: pnpm supabase:status  (prints current keys)

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-status

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-status

# Web admin only (bypasses RLS for server tasks if needed)
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-from-supabase-status

# Test admin phone (matches supabase/config.toml test_otp)
ADMIN_PHONE_NUMBERS=+919876543210

# Mobile physical device — set LAN IP from Metro QR (exp://192.168.x.x:8082):
# EXPO_PUBLIC_SUPABASE_LAN_URL=http://192.168.0.113:54321
# Android emulator: EXPO_PUBLIC_SUPABASE_LAN_URL=http://10.0.2.2:54321

# If Map tab stays on "Loading map…", force react-native-maps fallback:
# EXPO_PUBLIC_FORCE_LEGACY_MAP=1
